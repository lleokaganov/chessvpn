#!/bin/bash
# Privileged helper for the chessvpn desktop client. The ONLY thing the user is
# allowed to run as root without a password (see /etc/sudoers.d/chessvpn). It just
# starts/stops the bundled sing-box core in TUN mode — nothing else.
#
#   chessvpn-helper start <config.json>   run sing-box until 'stop' is called
#   chessvpn-helper stop                  tear the tunnel down
set -u
SB=/usr/local/lib/chessvpn/sing-box
RUN=/run/chessvpn

case "${1:-}" in
  start)
    cfg="${2:-}"
    [ -n "$cfg" ] && [ -f "$cfg" ] || { echo "usage: start <config>"; exit 2; }
    mkdir -p "$RUN"
    cp -f "$cfg" "$RUN/config.json"
    : > "$RUN/active"
    "$SB" run -c "$RUN/config.json" &
    pid=$!
    # run until 'stop' removes the flag, or the core dies on its own
    while [ -e "$RUN/active" ] && kill -0 "$pid" 2>/dev/null; do sleep 1; done
    kill "$pid" 2>/dev/null
    wait "$pid" 2>/dev/null
    rm -f "$RUN/active"
    ;;
  stop)
    rm -f "$RUN/active"
    ;;
  *)
    echo "usage: chessvpn-helper {start <config>|stop}"
    exit 2
    ;;
esac
